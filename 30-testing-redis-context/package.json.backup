{
  "name": "30-testing-redis-context",
  "version": "1.0.0",
  "description": "Testing Redis context patterns for SyntropyLog - showing declarative testing",
  "main": "src/index.ts",
  "scripts": {
    "start": "ts-node -r dotenv/config src/index.ts",
    "dev": "vitest run",
    "test": "vitest",
    "test:watch": "vitest --watch",
    "test:coverage": "vitest run --coverage"
  },
  "dependencies": {
    "redis": "^4.6.12",
    "syntropylog": "0.9.17",
    "@syntropylog/types": "0.1.5",
    "chalk": "^5.4.1"
  },
  "devDependencies": {
    "@types/node": "^20.10.5",
    "dotenv": "^16.0.0",
    "ts-node": "^10.9.0",
    "typescript": "^5.8.3",
    "vitest": "^1.1.0",
    "@vitest/coverage-v8": "^1.1.0"
  }
}
