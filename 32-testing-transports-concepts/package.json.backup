{
  "name": "32-testing-transports-concepts",
  "version": "1.0.0",
  "description": "Testing Transports Concepts - Understanding how transports work as spies",
  "main": "src/index.ts",
  "scripts": {
    "dev": "npm run build && npm run start",
    "test": "vitest",
    "test:watch": "vitest --watch",
    "test:coverage": "vitest --run --coverage",
    "build": "tsc",
    "start": "node dist/index.js"
  },
  "dependencies": {
    "redis": "^4.6.12",
    "syntropylog": "0.9.17",
    "@syntropylog/types": "0.1.5",
    "chalk": "^5.4.1"
  },
  "devDependencies": {
    "vitest": "^1.6.1",
    "typescript": "^5.0.0",
    "@vitest/coverage-v8": "^1.6.1"
  },
  "keywords": [
    "syntropylog",
    "testing",
    "transports",
    "spies",
    "concepts"
  ],
  "author": "SyntropySoft",
  "license": "Apache-2.0"
}
