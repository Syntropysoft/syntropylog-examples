# Copy to .env to override. Defaults already point at the docker-compose infra.
KAFKA_BROKERS=localhost:9092
REDIS_URL=redis://localhost:6379
LOG_LEVEL=info

# Ports (host)
GATEWAY_PORT=3000
ORDERS_PORT=3001
PAYMENTS_PORT=3002
INVENTORY_PORT=3003

# Where the gateway tells the browser to open the WebSocket / API
GATEWAY_PUBLIC_URL=http://localhost:3000
